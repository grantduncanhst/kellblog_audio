# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kellblog-audio

# Public URLs
KELLBLOG_AUDIO_PUBLIC_URL=https://kellblog.thisisgrant.com

# TTS (kokoro | chatterbox | piper)
KELLBLOG_TTS_PROVIDER=chatterbox
KELLBLOG_CHATTERBOX_EXAGGERATION=0.4
# Torch device for Chatterbox: auto | mps | cpu | cuda (auto prefers Apple GPU / CUDA)
KELLBLOG_CHATTERBOX_DEVICE=auto
# KELLBLOG_KOKORO_VOICE=am_michael

# Optional skip slugs (comma-separated)
# KELLBLOG_SKIP_SLUGS=
